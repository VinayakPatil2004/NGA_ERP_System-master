<!DOCTYPE html>
<html>

<head>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Comic+Sans+MS&display=swap');

        body {
            font-family: 'Inter', 'Comic Sans MS', sans-serif;
            padding: 0;
            margin: 0;
            color: #333;
            font-size: 11px;
            background: #fff;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            padding: 15mm;
            margin: auto;
            border: 1px solid #eee;
            position: relative;
            box-sizing: border-box;
            page-break-after: always;
        }

        .container {
            border: 4px solid #5F823B;
            padding: 15px;
            height: 100%;
            border-radius: 20px;
            position: relative;
            box-sizing: border-box;
        }

        header {
            text-align: center;
            border-bottom: 2px solid #5F823B;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }

        .logo {
            width: 80px;
            margin-bottom: 5px;
        }

        h1 {
            margin: 0;
            color: #5F823B;
            font-size: 24px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .address {
            font-size: 9px;
            color: #666;
            margin-top: 5px;
            font-weight: bold;
        }

        .report-title {
            background: #5F823B;
            color: #fff;
            padding: 5px 20px;
            display: inline-block;
            font-weight: 900;
            border-radius: 50px;
            margin-top: 10px;
            font-size: 12px;
        }

        .student-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 15px;
            padding: 10px;
            background: #f9fdf4;
            border: 1px solid #d4e3c1;
            border-radius: 10px;
        }

        .info-item {
            display: flex;
            gap: 5px;
        }

        .label {
            font-weight: 900;
            color: #5F823B;
            min-width: 90px;
        }

        .value {
            border-bottom: 1px dotted #5F823B;
            flex: 1;
            font-weight: bold;
        }

        .section-heading {
            background: #5F823B;
            color: #fff;
            padding: 6px 15px;
            font-weight: 900;
            font-size: 12px;
            border-radius: 5px;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
        }

        th,
        td {
            border: 1.5px solid #5F823B;
            padding: 6px;
            text-align: center;
        }

        th {
            background: #5F823B;
            color: #fff;
            text-transform: uppercase;
            font-size: 10px;
        }

        .subject-group {
            background: #eef5e6;
            font-weight: 900;
            text-align: left;
            color: #5F823B;
            padding-left: 10px;
        }

        .skill-label {
            text-align: left;
            padding-left: 20px;
            width: 60%;
            font-weight: bold;
            color: #555;
        }

        .grade-val {
            font-weight: 900;
            color: #5F823B;
            font-size: 12px;
        }

        /* PAGE 2 SPECIFIC */
        .page-2 {
            page-break-before: always;
        }

        .attendance-box {
            border: 2px solid #5F823B;
            margin-top: 20px;
            border-radius: 15px;
            overflow: hidden;
        }

        .attendance-header {
            background: #5F823B;
            color: #fff;
            padding: 8px;
            font-weight: 900;
            text-align: center;
            font-size: 11px;
        }

        .attendance-body {
            display: grid;
            grid-template-columns: 1fr 1fr;
            text-align: center;
        }

        .term-box {
            padding: 10px;
            border-right: 1px solid #5F823B;
        }

        .term-label {
            font-weight: 900;
            color: #5F823B;
            margin-bottom: 5px;
        }

        .term-val {
            font-size: 18px;
            font-weight: 900;
            color: #333;
        }

        .sig-container {
            margin-top: 40px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
        }

        .sig-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 40px;
        }

        .sig-box {
            text-align: center;
            width: 140px;
        }

        .sig-line {
            border-top: 1.5px solid #5F823B;
            margin-bottom: 5px;
        }

        .sig-text {
            font-size: 9px;
            font-weight: 900;
            color: #5F823B;
            text-transform: uppercase;
        }

        .footer-branding {
            position: absolute;
            bottom: 20px;
            left: 15px;
            right: 15px;
            text-align: center;
        }

        .promotion-msg {
            color: #d32f2f;
            font-family: 'Comic Sans MS', cursive;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .promotion-status {
            font-weight: 900;
            color: #5F823B;
            font-size: 13px;
            text-transform: uppercase;
            margin-bottom: 15px;
        }

        .promo-val {
            border-bottom: 2px solid #5F823B;
            padding: 0 15px;
            color: #2e7d32;
        }

        .reopening-notice {
            background: #ffebee;
            border: 2px solid #ffcdd2;
            padding: 10px 20px;
            border-radius: 50px;
            display: inline-block;
            color: #c62828;
            font-weight: 900;
            font-size: 11px;
            text-transform: uppercase;
        }

        .watermark-img {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            opacity: 0.04;
            width: 60%;
            z-index: -1;
        }
    </style>
</head>

<body>
    <!-- PAGE 1: ACADEMICS -->
    <div class="page">
        <div class="container">
            <img src="<%= logo %>" class="watermark-img">
            <header>
                <img src="<%= logo %>" class="logo">
                <h1>NEW GRACE ACADEMY</h1>
                <div class="address">
                    EKTA NAGAR, BOARGAD, SHIRISH SOCIETY, NASHIK, MAHARASHTRA 422004<br>
                    CONTACT: +91 7770055574 | EMAIL: NEWGRACE.EDU.NSK@GMAIL.COM
                </div>
                <div class="report-title">PRE-PRIMARY PROGRESS REPORT</div>
            </header>

            <div class="student-info">
                <div class="info-item"><span class="label">NAME:</span> <span class="value">
                        <%= student.name %>
                    </span></div>
                <div class="info-item"><span class="label">ROLL NO:</span> <span class="value">
                        <%= enrollment.roll_number %>
                    </span></div>
                <div class="info-item"><span class="label">CLASS:</span> <span class="value">
                        <%= classroom.name %>
                    </span></div>
                <div class="info-item"><span class="label">ACAD YEAR:</span> <span class="value">
                        <%= academicYear %>
                    </span></div>
            </div>

            <div class="section-heading">What I've Achieved</div>
            <table>
                <thead>
                    <tr>
                        <th style="text-align: left; padding-left: 15px;">Sub. & Skill</th>
                        <th style="width: 80px;">I Term</th>
                        <th style="width: 80px;">II Term</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="subject-group">
                        <td colspan="3">ENGLISH</td>
                    </tr>
                    <tr>
                        <td class="skill-label">Reading</td>
                        <td class="grade-val">
                            <%= marks.english_reading_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.english_reading_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Writing</td>
                        <td class="grade-val">
                            <%= marks.english_writing_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.english_writing_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Phonics</td>
                        <td class="grade-val">
                            <%= marks.english_phonics_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.english_phonics_t2 || '-' %>
                        </td>
                    </tr>

                    <tr class="subject-group">
                        <td colspan="3">MATHS</td>
                    </tr>
                    <tr>
                        <td class="skill-label">No. Recognition</td>
                        <td class="grade-val">
                            <%= marks.maths_recognition_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.maths_recognition_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">No. Counting</td>
                        <td class="grade-val">
                            <%= marks.maths_counting_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.maths_counting_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Writing</td>
                        <td class="grade-val">
                            <%= marks.maths_writing_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.maths_writing_t2 || '-' %>
                        </td>
                    </tr>

                    <tr class="subject-group">
                        <td colspan="3">HINDI</td>
                    </tr>
                    <tr>
                        <td class="skill-label">Reading</td>
                        <td class="grade-val">
                            <%= marks.hindi_reading_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.hindi_reading_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Writing</td>
                        <td class="grade-val">
                            <%= marks.hindi_writing_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.hindi_writing_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Vocabulary</td>
                        <td class="grade-val">
                            <%= marks.hindi_vocabulary_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.hindi_vocabulary_t2 || '-' %>
                        </td>
                    </tr>

                    <tr class="subject-group">
                        <td colspan="3">ART & CRAFT</td>
                    </tr>
                    <tr>
                        <td class="skill-label">Drawing</td>
                        <td class="grade-val">
                            <%= marks.art_drawing_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.art_drawing_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Coloring</td>
                        <td class="grade-val">
                            <%= marks.art_coloring_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.art_coloring_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Activities</td>
                        <td class="grade-val">
                            <%= marks.art_activities_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.art_activities_t2 || '-' %>
                        </td>
                    </tr>

                    <tr>
                        <td class="subject-group">G.K.</td>
                        <td class="grade-val">
                            <%= marks.gk_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.gk_t2 || '-' %>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- PAGE 2: CO-CURRICULAR & CHARACTER -->
    <div class="page">
        <div class="container">
            <img src="<%= logo %>" class="watermark-img">

            <div class="section-heading" style="margin-top: 10px;">What Else I Am Trained For</div>
            <table>
                <thead>
                    <tr>
                        <th style="text-align: left; padding-left: 15px;">Sub. & Skill</th>
                        <th style="width: 80px;">I Term</th>
                        <th style="width: 80px;">II Term</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="skill-label">Sports</td>
                        <td class="grade-val">
                            <%= marks.sports_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.sports_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Music</td>
                        <td class="grade-val">
                            <%= marks.music_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.music_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Dance</td>
                        <td class="grade-val">
                            <%= marks.dance_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.dance_t2 || '-' %>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="section-heading">Personality Character</div>
            <table>
                <thead>
                    <tr>
                        <th style="text-align: left; padding-left: 15px;">Trait</th>
                        <th style="width: 80px;">I Term</th>
                        <th style="width: 80px;">II Term</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="skill-label">Social Interaction</td>
                        <td class="grade-val">
                            <%= marks.social_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.social_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Etiquettes</td>
                        <td class="grade-val">
                            <%= marks.etiquettes_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.etiquettes_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Personal Hygiene</td>
                        <td class="grade-val">
                            <%= marks.hygiene_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.hygiene_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Attention</td>
                        <td class="grade-val">
                            <%= marks.attention_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.attention_t2 || '-' %>
                        </td>
                    </tr>
                    <tr>
                        <td class="skill-label">Creativity</td>
                        <td class="grade-val">
                            <%= marks.creativity_t1 || '-' %>
                        </td>
                        <td class="grade-val">
                            <%= marks.creativity_t2 || '-' %>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="attendance-box">
                <div class="attendance-header">ATTENDANCE RECORD</div>
                <div class="attendance-body">
                    <div class="term-box">
                        <div class="term-label">I TERM</div>
                        <div class="term-val">
                            <%= marks.attendance_t1 || '00' %> / <%= marks.total_days_t1 || '00' %>
                        </div>
                    </div>
                    <div class="term-box" style="border-right: 0;">
                        <div class="term-label">II TERM</div>
                        <div class="term-val">
                            <%= marks.attendance_t2 || '00' %> / <%= marks.total_days_t2 || '00' %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="sig-container">
                <div class="sig-box">
                    <div class="sig-line"></div>
                    <div class="sig-text">Class Teacher</div>
                </div>
                <div class="sig-box">
                    <div class="sig-line"></div>
                    <div class="sig-text">Supervisor</div>
                </div>
                <div class="sig-box">
                    <div class="sig-line"></div>
                    <div class="sig-text">Principal</div>
                </div>
                <div class="sig-box">
                    <div class="sig-line"></div>
                    <div class="sig-text">Parent</div>
                </div>
            </div>

            <% function getNextClass(currentClass) { if (!currentClass) return '---' ; const
                name=currentClass.toLowerCase(); if (name.includes('nursery')) return 'Jr. KG' ; if
                (name.includes('junior') || name.includes('jr')) return 'Sr. KG' ; if (name.includes('senior') ||
                name.includes('sr')) return 'I st' ; if (name.includes('1st') || name.includes('i ')) return ' II nd';
                return 'Next Class' ; } %>

                <div class="footer-branding">
                    <div class="promotion-msg">"I am ready to climb the next step"</div>
                    <div class="promotion-status">
                        Passed & Promoted to Std: <span class="promo-val">
                            <%= getNextClass(classroom.name) %>
                        </span>
                    </div>
                    <div class="reopening-notice">
                        School Reopens on: <%= marks.reopening_date_t2 || '06/04/2026' %> at <%= marks.reopening_time_t2
                                || '8:00 am' %>
                    </div>
                </div>
        </div>
    </div>
</body>

</html>